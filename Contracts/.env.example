# Environment Variables for EscrowX Contract Deployment

# Private key for deployment (DO NOT COMMIT THE ACTUAL .env FILE)
PRIVATE_KEY=your_private_key_here

# RPC URLs (for Foundry and testing)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
ANVIL_RPC_URL=http://localhost:8545

# Etherscan API Key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Gas reporting (optional)
REPORT_GAS=true

# Foundry specific settings
FOUNDRY_PROFILE=default

# ZK Verifier settings (for production deployment)
RISC_ZERO_IMAGE_ID=your_risc_zero_image_id_here
VLAYER_PROVER_URL=https://your-vlayer-prover.com

# Treasury configuration
TREASURY_FEE_RATE=250  # 2.5% in basis points
MIN_LISTING_AMOUNT=1000000  # 1 USDC (6 decimals)
MAX_LISTING_AMOUNT=1000000000000  # 1M USDC

# Example values:
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/abc123def456
# ETHERSCAN_API_KEY=ABC123DEF456GHI789JKL012MNO345PQR
# PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef